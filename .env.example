# =================================================================
# CONFIGURAÇÃO DO CHATWOOT CUSTOMIZADO
# =================================================================

# Database (PostgreSQL)
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=postgres_secure_password_here
POSTGRES_DATABASE=chatwoot_production

# Redis
REDIS_PASSWORD=redis_secure_password_here

# Security - IMPORTANTE: Gere uma chave segura!
# Execute: docker run --rm ghcr.io/fazer-ai/chatwoot:latest bundle exec rake secret
SECRET_KEY_BASE=your_secret_key_base_here

# URLs
FRONTEND_URL=http://localhost:3000

# Email Configuration
MAILER_SENDER_EMAIL=noreply@seudominio.com
RESEND_API_KEY=

# =================================================================
# CUSTOMIZAÇÃO DO FRONTEND (BRANDING)
# =================================================================
# Cole a URL do ZIP/TAR.GZ com seus assets customizados
# Estrutura esperada:
# - logo.png (logo do app)
# - logo_thumbnail.png (favicon)
# - banner.png (imagem de login/cadastro)
# Exemplo: https://seusite.com/brand-assets.zip
BRAND_ASSETS_URL=

# =================================================================
# WHATSAPP (BAILEYS API)
# =================================================================
BAILEYS_PROVIDER_DEFAULT_CLIENT_NAME=Chatwoot
BAILEYS_API_KEY=default-api-key-change-me

# Logs
LOG_LEVEL=debug
BAILEYS_LOG_LEVEL=error
